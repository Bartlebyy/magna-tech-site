---
layout: base.njk
title: "Awards"
description: "Magna-Tech Electronic Co. has received Academy Scientific/Technical Awards for engineering contributions to motion picture sound."
permalink: "/about/awards/"
---
<div class="page-header">
  <div class="wrap">
    <p class="crumbs"><a href="/">Home</a> / <a href="/about/">About Us</a> / Awards</p>
    <h1>Awards</h1>
    <p class="dek">Recognized by the Academy of Motion Picture Arts and Sciences for engineering contributions to motion picture sound.</p>
  </div>
</div>

<section class="block">
  <div class="wrap">
    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); margin-bottom: 2rem;">
      {% for n in range(1, 8) %}
      <img src="/img/awards/award-{{ n }}.jpg" alt="Magna-Tech Academy Award certificate, photo {{ n }}" loading="lazy" style="border:1px solid #ddd4bf;">
      {% endfor %}
    </div>

    {% for c in awards.citations %}
    <div class="card" style="border-top-color: var(--brass); margin-bottom: 1.5rem;">
      <span class="badge">{{ c.year }}</span>
      <h3>{{ c.type }}</h3>
      <p><strong>{{ c.recipient }}</strong></p>
      <p>&ldquo;{{ c.citation }}&rdquo;</p>
    </div>
    {% endfor %}

    {% if awards.relatedIndividualAwards.entries.length %}
    <h2>Related Awards to Company Founders</h2>
    <p class="text-muted">{{ awards.relatedIndividualAwards.note }}</p>
    <ul>
      {% for e in awards.relatedIndividualAwards.entries %}
      <li><strong>{{ e.year }}</strong> — {{ e.recipient }}: &ldquo;{{ e.citation }}&rdquo;</li>
      {% endfor %}
    </ul>
    {% endif %}

    <p class="text-muted" style="margin-top:2rem; font-size: 0.85rem;">
      Sourced from Academy Scientific and Technical Awards records. If you have the original
      certificates or photographs, we’d rather cite those directly — send them to
      <a href="mailto:{{ company.email }}">{{ company.email }}</a>.
    </p>
  </div>
</section>
